---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
const desc = `关于 ${siteConfig.name} — 我们致力于为中文用户提供最新、最全面的 Telegram 使用教程与安全设置指南，涵盖下载安装、隐私保护、账号安全、功能技巧等全品类内容。独立运营，持续更新。`;
---

<BaseLayout title={`关于我们 — ${siteConfig.name}`} description={desc}>
  <div class="static-page">
    <h1>关于我们</h1>
    <div class="content">
      <p>{siteConfig.name} 是一个独立的 Telegram 教程站点，致力于为中文用户提供最新、最全面的 Telegram 使用指南。</p>
      <p>我们的教程涵盖 Telegeram 下载安装、功能使用、常见问题解决等多个方面，帮助用户轻松上手。</p>
      <h2>我们的承诺</h2>
      <ul>
        <li>📝 内容持续更新，跟进最新版本</li>
        <li>🔍 教程经过实测，确保准确有效</li>
        <li>💬 图文并茂，降低学习门槛</li>
      </ul>
      <h2>免责声明</h2>
      <p>本站为独立第三方教程站点，与 Telegram 官方无关。所有内容基于公开信息整理，仅供学习参考。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .static-page { max-width: 780px; margin: 40px auto; padding: 0 24px; }
  .static-page h1 { font-family: var(--f-heading); font-size: 1.8rem; margin-bottom: 24px; text-align: center; }
  .content h2 { font-size: 1.3rem; margin: 28px 0 12px; }
  .content p { color: var(--c-text-2); margin: 12px 0; }
  .content ul { padding-left: 20px; color: var(--c-text-2); }
  .content li { margin: 8px 0; }
</style>
