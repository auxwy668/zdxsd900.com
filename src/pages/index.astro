---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = articles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 21);

const c = siteConfig.colors;

const pageCSS = `
.tl-main{position:relative;padding-bottom:60px}
.tl-main .tl-news-float{position:absolute;top:80px;right:50px;border-left:5px solid ${c.primary};padding:20px}
.news-float-title{font-weight:700;margin-bottom:10px}
.news_1,.news_2,.news_3{font-size:13px;color:${c.textSecondary};line-height:1.8}

.logo-container{text-align:center;overflow:hidden}
.logo-zone{display:flex;justify-content:center;align-items:center;margin-top:50px}
.logo{width:128px;height:128px;background-image:url(/images/window_img.png);background-repeat:no-repeat;background-size:cover;border-radius:24px;margin:0 auto}
.logo-title{font-size:32px;font-weight:700;margin-top:5px;color:${c.textPrimary}}
.logo-title img{vertical-align:middle}

.download-container{overflow:hidden;display:flex;justify-content:center}
.download-group{margin-top:40px;display:flex;justify-content:center;flex-wrap:wrap}
.tl-main .download-group-item{margin-bottom:70px}
.download-group-item-img-zone{display:flex;justify-content:center;cursor:pointer;align-items:center}
.download_item_video_window{position:relative}
.down_load_img{margin:10px 0}
.download-group-item-content{display:flex;justify-content:center}
.download-group-item-content a{color:${c.primary};font-weight:700;text-decoration:none}

.myButton{background-color:${c.primary};border-radius:20px;border:1px solid ${c.btnBorder};display:inline-block;cursor:pointer;color:#fff;font-size:20px;padding:16px 31px;text-decoration:none;text-shadow:0 1px 0 rgba(107,212,253,0.55);transition:background .2s}
.myButton:hover{background-color:${c.primaryHover}}
.myButton:active{position:relative;top:1px}
.myButton img{display:block;width:100%;max-width:350px;height:auto}

.introduce-container{margin-bottom:50px}
.tl-main .introduce-title{text-align:center;font-weight:700;font-size:20px;margin-bottom:30px;color:${c.textPrimary}}
.introduce-main{display:flex;justify-content:center}
.introduce-group{display:flex;flex-wrap:wrap;width:100%;justify-content:space-between;max-width:900px}
.introduce-group-item{width:27%;margin:20px 0}
.introduce-group-item-img-zone{display:flex;justify-content:center;align-items:center}
.introduce-group-item-img{width:160px;height:160px}
.introduce-group-item-img img{width:100%}
.introduce-group-item-title{text-align:center;color:${c.featTitle};font-size:20px;margin-top:10px;margin-bottom:5px}
.introduce-group-item-content{text-align:center;font-size:15px;margin-bottom:20px;color:${c.textSecondary}}
.introduce-group-item-content img{vertical-align:middle;width:70px;height:19px}

/* ── Articles section (after features, matches lccygs grid) ── */
.articles{max-width:1100px;margin:0 auto;padding:0 24px 60px}
.articles h2{text-align:center;font-size:22px;font-weight:700;margin-bottom:36px;color:${c.textPrimary}}
.art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.art-card{background:${c.bg};border-radius:12px;overflow:hidden;border:1px solid #e8ecf1;transition:transform .2s,box-shadow .2s;text-decoration:none;color:inherit;display:block}
.art-card:hover{transform:translateY(-3px);box-shadow:0 8px 30px rgba(0,0,0,.08)}
.art-card-body{padding:20px}
.art-card .art-tag{display:inline-block;font-size:11px;font-weight:600;padding:3px 10px;border-radius:6px;margin-bottom:10px}
.art-tag.download,.art-tag.guide{background:#e0f2fe;color:#0369a1}
.art-tag.fix{background:#fef3c7;color:#92400e}
.art-card h3{font-size:15px;font-weight:700;line-height:1.4;margin-bottom:8px;color:${c.textPrimary};display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.art-card p{font-size:13px;color:${c.textMuted};line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

@media(max-width:768px){
  .tl-main .tl-news-float{display:none}
  .logo-title{font-size:22px}
  .download-group{flex-direction:column;align-items:center}
  .introduce-group-item{width:45%}
  .art-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:480px){
  .introduce-group-item{width:100%}
  .art-grid{grid-template-columns:1fr}
}
`;
---

<BaseLayout>
  <div class="tl-main">

    <!-- ── 更新浮窗 ── -->
    <div class="tl-news-float">
      <div class="news-float-title news-float-time">{siteConfig.newsFloat.date}</div>
      <div class="news-float-title news-float-lable">{siteConfig.newsFloat.label}</div>
      {siteConfig.newsFloat.items.map((item, i) => (
        <div class={`news_${i + 1}`}>{item}</div>
      ))}
    </div>

    <!-- ── Logo 区 ── -->
    <div class="logo-container">
      <div class="logo-zone">
        <div class="logo"></div>
      </div>
      <h1 class="logo-title">{siteConfig.logo.text}</h1>
      <h1 class="logo-title">
        <img src={`/images/${siteConfig.logo.img}`} width={siteConfig.logo.imgWidth} height={siteConfig.logo.imgHeight} alt={siteConfig.logo.text} />
      </h1>
    </div>

    <!-- ── 下载区 ── -->
    <div class="download-container">
      <div class="download-group">
        {siteConfig.downloadButtons.map(btn => (
          <div class="download-group-item">
            <div class="download-group-item-img-zone download_item_video_window">
              <img class="down_load_img" src={`/images/${btn.img}`} loading="lazy" alt="" />
            </div>
            <div class="download-group-item-content">
              <a href="javascript:void(0)" onclick={btn.onClick}>
                <div class="myButton">
                  <img src={`/images/${btn.btnSvg}`} width="350" height="30" alt="下载" />
                </div>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Features 区 ── -->
    <div class="introduce-container width">
      <h2 class="introduce-title why_tg">
        <img src="/images/TG2.svg" width="250" height="35" alt="" />
      </h2>
      <div class="introduce-main">
        <div class="introduce-group">
          {siteConfig.features.map((f, i) => (
            <div class="introduce-group-item">
              <div class="introduce-group-item-img-zone">
                <div class={`introduce-group-item-img introduce-group-item-img-${i + 1}`}>
                  <img class="img_gif" src={`/images/${f.gif}`} alt={f.title} loading="lazy" style="display:inline" />
                </div>
              </div>
              <div class="introduce-group-item-title introduce_title_{i + 1}">{f.title}</div>
              <h4 class="introduce-group-item-content">
                <img src="/images/TT.svg" width="70" height="19" alt="" />
                <span class={`introduce_${i + 1}`}> {f.desc}</span>
              </h4>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── 最新文章区 ── -->
    <section class="articles">
      <h2>最新教程</h2>
      <div class="art-grid">
        {sorted.map(article => {
          const cat = article.data.category || 'guide';
          return (
            <a href={`/${article.id}/`} class="art-card">
              <div class="art-card-body">
                <span class={`art-tag ${cat}`}>{siteConfig.catLabels?.[cat] || article.data.category}</span>
                <h3>{article.data.title}</h3>
                <p>{article.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>

  </div>

  <style set:html={pageCSS} />
</BaseLayout>
