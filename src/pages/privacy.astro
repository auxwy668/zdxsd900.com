---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
---

<BaseLayout title={`隐私政策 — ${siteConfig.name}`}>
  <div class="static-page">
    <h1>隐私政策</h1>
    <div class="content">
      <p>最后更新：2026年6月24日</p>
      <h2>信息收集</h2>
      <p>本站为纯静态网站，不收集、不存储任何用户个人信息。我们不使用 Cookie、不运行用户追踪脚本、不要求用户注册或提交任何数据。</p>
      <h2>第三方服务</h2>
      <p>本站使用 Cloudflare Pages 提供静态托管服务。Cloudflare 可能会收集基本的访问日志（IP 地址、User-Agent）用于安全防护和性能优化，详见 Cloudflare 隐私政策。</p>
      <h2>外部链接</h2>
      <p>本站包含指向 Telegram 官方网站和其他第三方网站的外部链接。我们对这些网站的隐私实践不承担任何责任。</p>
      <h2>联系我们</h2>
      <p>如有隐私相关问题，请通过 <a href="mailto:{siteConfig.email}">{siteConfig.email}</a> 联系我们。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .static-page { max-width: 780px; margin: 40px auto; padding: 0 24px; }
  .static-page h1 { font-family: var(--f-heading); font-size: 1.8rem; margin-bottom: 24px; text-align: center; }
  .content h2 { font-size: 1.3rem; margin: 28px 0 12px; }
  .content p { color: var(--c-text-2); margin: 12px 0; }
</style>
