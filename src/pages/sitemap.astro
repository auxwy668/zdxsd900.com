---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/siteConfig';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by category
const grouped = {} as Record<string, typeof sorted>;
for (const a of sorted) {
  const cat = a.data.category || 'guide';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(a);
}

const categoryOrder = siteConfig.categories.map(c => c.id);
const c = siteConfig.colors;

const title = `网站地图 - ${siteConfig.title}`;
const description = `${siteConfig.title} Telegram 隐私安全教程全站导航地图，按隐私保护、账号安全、加密技术、使用指南四大分类浏览全部教程文章。`;
---

<BaseLayout title={title} description={description}>
  <section style="max-width:900px;margin:0 auto;padding:48px 24px">
    <h1 style="font-size:28px;font-weight:800;margin-bottom:8px">网站地图</h1>
    <p style="color:{c.textSecondary};font-size:14px;margin-bottom:40px">{siteConfig.title} 全站文章导航目录</p>

    {categoryOrder.map(catId => {
      const cat = siteConfig.categories.find(c => c.id === catId);
      const items = grouped[catId] || [];
      if (items.length === 0) return null;
      return (
        <div style="margin-bottom:40px">
          <h2 style="font-size:18px;font-weight:700;margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid {c.primary};color:{c.textPrimary}">
            <a href={`/articles/?category=${catId}`} style="color:inherit;text-decoration:none">{cat?.name || catId}</a>
            <span style="font-size:13px;font-weight:400;color:{c.textMuted};margin-left:8px">({items.length} 篇)</span>
          </h2>
          <ul style="list-style:none;display:grid;grid-template-columns:repeat(2,1fr);gap:8px 24px">
            {items.map(a => (
              <li>
                <a href={`/${a.id}/`}
                   style="font-size:14px;color:{c.textSecondary};text-decoration:none;display:block;padding:4px 0;transition:color .2s;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                   onmouseover="this.style.color='{c.primary}'"
                   onmouseout="this.style.color='{c.textSecondary}'">
                  {a.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      );
    })}

    {categoryOrder.every(catId => (grouped[catId] || []).length === 0) && (
      <p style="color:{c.textMuted};text-align:center;padding:60px 0">暂无内容</p>
    )}
  </section>
</BaseLayout>

<style>
  h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
  @media (max-width: 600px) {
    ul { grid-template-columns: 1fr !important; }
  }
</style>
